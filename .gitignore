```gitignore
# Dependencies
node_modules/
.yarn/
npm-debug.log*
# Build outputs
dist/
build/
coverage/
# Logs
*.log
# Environment variables
.env
.env.local
.env.*
# IDE files
.vscode/
.idea/
*.swp
*.swo
# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
# Temporary files
*.tmp
*.temp
# OS generated files
.DS_Store
Thumbs.db
# Testing
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
# Package manager
package-lock.json
yarn.lock
```