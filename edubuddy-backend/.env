# EduBuddy Backend Configuration

# Flask Secret Key
SECRET_KEY=edubuddy-super-secret-key-2024-secure-random-string

# Email Configuration (Gmail SMTP) - OPTIONAL FOR DEVELOPMENT
# Leave as is to use development mode (codes printed to console)
# To enable real email sending:
# 1. Create a Gmail account
# 2. Enable 2-Factor Authentication
# 3. Generate an App Password: https://myaccount.google.com/apppasswords
# 4. Replace below with your actual credentials:
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# OpenRouter API Key for AI Chat (Free tier available)
# Get your free API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key

# DEVELOPMENT MODE:
# When MAIL_USERNAME and MAIL_PASSWORD contain "your-", codes are printed to console
# Check the Flask backend terminal for your verification code
